<Window x:Class="zakonWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zakonWPF"
        mc:Ignorable="d"
        Title="Закон Ома" Height="300" Width="750" Background="#d8c3e3">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="Label1" Text="Напряжение (Вольт)" FontWeight="Bold" FontSize="14" Width="150" VerticalAlignment="Center"/>
                <TextBox x:Name="Input1" Width="240" Height="30" FontSize="14" ToolTip="Введите число"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="Label2" Text="Сопротивление (Ом)" FontWeight="Bold" FontSize="14" Width="150" VerticalAlignment="Center"/>
                <TextBox x:Name="Input2" Width="240" Height="30" FontSize="14" ToolTip="Введите число"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <TextBlock x:Name="ResultLabel" Text="Сила тока =" FontWeight="Bold" FontSize="16" Width="150" VerticalAlignment="Center"/>
                <TextBox x:Name="ResultBox" IsReadOnly="True" Width="250" Height="40" FontSize="16" ToolTip="Результат"/>
            </StackPanel>
        </StackPanel>

        <GroupBox Grid.Column="1" Width="270" Margin="30,0,30,120" Header="Вычисляемая величина:" >
            <StackPanel Grid.Column="1" Margin="20,0,0,0" >
                <RadioButton x:Name="RbCurrent" GroupName="CalcType" Content="Сила тока" IsChecked="True" Margin="0,5" FontSize="14" Checked="Rb_Checked"/>
                <RadioButton x:Name="RbVoltage" GroupName="CalcType" Content="Напряжение" Margin="0,5" FontSize="14" Checked="Rb_Checked"/>
                <RadioButton x:Name="RbResistance" GroupName="CalcType" Content="Сопротивление" Margin="0,5" FontSize="14" Checked="Rb_Checked"/>
            </StackPanel>
        </GroupBox>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="43,90,0,0">
            <Button Content="Вычислить" Width="100" Height="35" Margin="0,0,10,0" Click="CalculateButton_Click" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>

